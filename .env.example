# ============================================
# متغيرات البيئة - مشروع العملاء (Client)
# لا تضع هذا الملف في Git — انسخه إلى .env
# ============================================

# ── Supabase ──────────────────────────────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── JWT Secrets (64+ حرف عشوائي) ─────────────
# توليد: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING_MINIMUM
JWT_REFRESH_SECRET=CHANGE_THIS_TO_A_DIFFERENT_RANDOM_64_CHAR_STRING

# ── مفاتيح التشفير (64 hex chars = 32 bytes) ──
# توليد: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_ENCRYPTION_KEY=CHANGE_THIS_TO_A_64_HEX_CHAR_STRING
PROXY_ENCRYPTION_KEY=CHANGE_THIS_TO_A_64_HEX_CHAR_STRING
PROXY_HMAC_SECRET=CHANGE_THIS_TO_ANOTHER_64_HEX_CHAR_STRING
PROXY_API_KEY=CHANGE_THIS_TO_A_RANDOM_SECRET_KEY

# ── CORS ──────────────────────────────────────
# أضف رابط موقع العملاء فقط هنا
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── محفظة الإيداع ─────────────────────────────
VITE_DEPOSIT_ADDRESS=YOUR_SHAMCASH_WALLET_ADDRESS_FOR_RECEIVING_DEPOSITS

# ── إعدادات السيرفر ───────────────────────────
PORT=3000
NODE_ENV=production

# ── OTP - التحقق بخطوتين (Resend) ─────────────
RESEND_API_KEY=re_YOUR_RESEND_API_KEY
FROM_EMAIL=noreply@yourdomain.com

# ── Google OAuth ──────────────────────────────
# اذهب إلى: https://console.cloud.google.com
# أضف Authorized redirect URI:
#   http://localhost:3000/api/auth/google/callback  (تطوير)
#   https://yourdomain.com/api/auth/google/callback  (إنتاج)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# ── اختياري ───────────────────────────────────
# TRUST_PROXY=1
# REDIS_URL=redis://localhost:6379
